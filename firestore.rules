rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && (
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(["name", "updatedAt"])
                      ||
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(["onboardingStep"])
                    );
    }

    match /userPreferences/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(["fontSize", "contrast", "spacing", "interfaceMode",
                                  "enhancedFeedback", "confirmCriticalActions",
                                  "reduceMotion", "remindersEnabled", "updatedAt"])
                    && request.resource.data.fontSize in ["normal", "large", "extraLarge"]
                    && request.resource.data.contrast in ["default", "high", "dark"]
                    && request.resource.data.spacing in ["normal", "expanded"]
                    && request.resource.data.interfaceMode in ["basic", "complete"]
                    && request.resource.data.enhancedFeedback in [true, false]
                    && request.resource.data.confirmCriticalActions in [true, false]
                    && request.resource.data.reduceMotion in [true, false]
                    && request.resource.data.remindersEnabled in [true, false];
    }

  match /activities/{docId} {
    allow create: if request.auth != null
                  && request.auth.uid == request.resource.data.userId;
    allow read:   if request.auth != null
                  && request.auth.uid == resource.data.userId;

    function isReminderUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(["reminder.readAt", "reminder.dismissedAt", "updatedAt"])
        && request.resource.data.reminder.readAt is timestamp
        && request.resource.data.reminder.readAt == resource.data.reminder.readAt
        || request.resource.data.reminder.dismissedAt is timestamp
        && request.resource.data.reminder.dismissedAt == resource.data.reminder.dismissedAt;
    }

    allow update: if request.auth != null
                  && request.auth.uid == resource.data.userId
                  && (
                    // full activity update (create/edit)
                    (request.auth.uid == request.resource.data.userId
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.createdAt == resource.data.createdAt)
                    ||
                    // reminder read/dismiss only
                    isReminderUpdate()
                  );
    allow delete: if request.auth != null
                  && request.auth.uid == resource.data.userId;
  }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
